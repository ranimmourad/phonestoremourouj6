{
  "name": "phone-store-mourouj6",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "wrangler pages dev dist",
    "deploy": "npm run build && wrangler pages deploy dist",
    "dev:sandbox": "wrangler pages dev dist --d1=DB --local --ip 0.0.0.0 --port 3000",
    "db:migrate:local": "wrangler d1 migrations apply phone-store-db --local",
    "db:seed": "wrangler d1 execute phone-store-db --local --file=./seed.sql",
    "db:reset": "rm -rf .wrangler/state/v3/d1 && npm run db:migrate:local && npm run db:seed"
  },
  "dependencies": {
    "hono": "^4.12.12"
  },
  "devDependencies": {
    "@hono/vite-dev-server": "^0.18.2",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "vite": "^6.3.5"
  }
}
